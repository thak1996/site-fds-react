# -----------------------------------------------------------------------------
# Runtime & App Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
APP_PORT=3000

# Base URL for metadata and canonical tags
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# E-mail (SMTP via Nodemailer)
# -----------------------------------------------------------------------------
# For Docker (Mailpit): MAIL_HOST=mailpit, MAIL_PORT=1025, MAIL_ENCRYPTION=
# For Gmail:           MAIL_HOST=smtp.gmail.com, MAIL_PORT=587, MAIL_ENCRYPTION=tls

MAIL_HOST=
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
# Options: "tls", "ssl", or leave empty for development
MAIL_ENCRYPTION=

# -----------------------------------------------------------------------------
# E-mail Identity & Notifications
# -----------------------------------------------------------------------------
MAIL_FROM_ADDRESS=contato@fdslogistica.com.br
MAIL_FROM_NAME="FDS Logística e Terceirização"

# Admin notification address for Contact and Quote forms
MAIL_COPY_ADDRESS=contato@fdslogistica.com.br
